# ========================================
# Data Breach OSINT Toolkit
# Environment Variables
# ========================================
# Copy this file to .env and configure

# ===== GOOGLE AUTH (Get from console.cloud.google.com) =====
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ===== GOOGLE ANALYTICS (Get from analytics.google.com) =====
GOOGLE_ANALYTICS_ID=G-YOUR_ID

# ===== PHONE LOOKUP API =====
# Your API - already configured below
PHONE_API_URL=https://nv6.ek4nsh.in/api/proxy

# ===== SECURITY =====
SESSION_SECRET=change_this_to_a_random_string

# ========================================
# How to get each key:
# ========================================

# GOOGLE_CLIENT_ID:
# 1. Go to console.cloud.google.com
# 2. Create new project or select existing
# 3. APIs & Services → Credentials
# 4. Create Credentials → OAuth client ID
# 5. Application type: Web application
# 6. Add authorized redirect URIs:
#    - http://localhost:3000
#    - https://yourdomain.vercel.app/callback
# 7. Copy the Client ID

# GOOGLE_CLIENT_SECRET:
# 1. Same as above - get from OAuth credentials
# 2. Copy the Client Secret

# GOOGLE_ANALYTICS_ID:
# 1. Go to analytics.google.com
# 2. Start Measurement
# 3. Enter website name and URL
# 4. Copy the Measurement ID (G-XXXXXXXXXX)

# SESSION_SECRET:
# 1. Generate: openssl rand -base64 32
# 2. Or use any random string

# ========================================
# Deploy to Vercel:
# ========================================
# vercel env add .env
# vercel deploy