# API Keys Configuration
# Copy this file to .env and fill in your values

# Phone Lookup API Key (required for phone lookup module)
PHONE_API_KEY=your_phone_api_key_here
PHONE_API_URL=https://api.example.com/phone

# Database (optional - for future updates)
DATABASE_URL=

# Session Secret (change this!)
SESSION_SECRET=your_super_secret_key_here

# Analytics (optional)
GOOGLE_ANALYTICS_ID=